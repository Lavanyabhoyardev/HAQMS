generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum AppointmentStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum QueueStatus {
  WAITING
  CALLING
  COMPLETED
  SKIPPED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(RECEPTIONIST)
  createdAt DateTime @default(now())

  doctor Doctor?
}

model Doctor {
  id              String   @id @default(uuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id])
  name            String
  specialization  String
  department      String
  consultationFee Float
  experience      Int
  availableFrom   String   @default("09:00")
  availableTo     String   @default("17:00")
  createdAt       DateTime @default(now())

  appointments Appointment[]
  queueTokens  QueueToken[]

  // Filter columns for doctor search and stats aggregation.
  @@index([department])
  @@index([specialization])
}

model Patient {
  id             String   @id @default(uuid())
  name           String
  email          String?
  phoneNumber    String
  age            Int
  gender         String
  medicalHistory String?
  createdAt      DateTime @default(now())

  appointments Appointment[]
  queueTokens  QueueToken[]
}

model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  doctorId        String
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  appointmentDate DateTime
  reason          String            @default("")
  status          AppointmentStatus @default(PENDING)
  createdAt       DateTime          @default(now())

  queueTokens QueueToken[]

  // Hard DB-level guarantee against double-booking the same physician at the
  // exact appointmentDate value — closes the TOCTOU race in the booking
  // handler. The (doctorId, appointmentDate) composite also serves as the
  // covering index for worklist lookups sorted by date.
  @@unique([doctorId, appointmentDate])

  // Per-doctor status grouping (reports.js groupBy by (doctorId, status)).
  @@index([doctorId, status])
  // Foreign-key index for patient-history lookups.
  @@index([patientId])
}

model QueueToken {
  id            String       @id @default(uuid())
  tokenNumber   Int
  // Date portion of the token's day. Stored as DATE (no time) so the
  // (doctorId, tokenNumber, tokenDate) unique gives one fresh sequence per
  // calendar day per doctor. Default is the DB's CURRENT_DATE so legacy
  // inserts (seed scripts, migrations) keep working without changes.
  tokenDate     DateTime     @default(dbgenerated("CURRENT_DATE")) @db.Date
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        Doctor       @relation(fields: [doctorId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  status        QueueStatus  @default(WAITING)
  createdAt     DateTime     @default(now())

  // Daily uniqueness — DB-side backstop to the advisory lock in queue.js.
  @@unique([doctorId, tokenNumber, tokenDate])

  // Used by the daily MAX(tokenNumber) aggregate and the today-queue
  // groupBy in reports.js.
  @@index([doctorId, createdAt])
  // Used by the live monitor board (status filter) and the doctor queue tab.
  @@index([status])
  // Foreign-key index for patient queue history.
  @@index([patientId])
}
