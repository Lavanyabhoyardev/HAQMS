PORT=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/haqms?schema=public"

# REQUIRED. The server refuses to boot without a strong JWT_SECRET.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Must be >=32 chars of high-entropy random data, unique per environment,
# and rotated on suspected compromise. Never commit the real value.
JWT_SECRET=""

# Access-token lifetime. Short by design — a stolen token expires quickly.
# Accepts the vercel/ms format: '15m', '1h', '8h', '24h'.
# A refresh-token flow is the next step if longer sessions are needed.
JWT_ACCESS_TTL="1h"

NODE_ENV="development"
